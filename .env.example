# OpenRouter (LLM provider)
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model
LLM_MODEL=anthropic/claude-opus-4.7

# Optional per-stage model routing (Phase 9). Each stage falls back to
# LLM_MODEL if unset. Cheaper models handle light stages; the strongest
# model is reserved for code generation.
# LLM_MODEL_CLASSIFIER=anthropic/claude-haiku-4.5
# LLM_MODEL_GREETER=anthropic/claude-haiku-4.5
# LLM_MODEL_REFINER=anthropic/claude-sonnet-4.6
# LLM_MODEL_PLANNER=anthropic/claude-sonnet-4.6
# LLM_MODEL_CODER=anthropic/claude-opus-4.7
# LLM_MODEL_REPORTER=anthropic/claude-haiku-4.5

# Optional: caches identical questions for this many seconds (Phase 9)
# RESULT_CACHE_TTL=600

# Optional: shows the demo on OpenRouter leaderboards
OPENROUTER_APP_NAME=Renty Analytics Demo
OPENROUTER_APP_URL=http://localhost:8501

# SQL Server connection (eJarAnalytics)
# IMPORTANT: use a STRICT READ-ONLY login here (e.g. renty_readonly).
# Provision one with: python scripts/setup_readonly_user.py
DB_SERVER=172.86.86.150
DB_DATABASE=eJarAnalytics
DB_USER=renty_readonly
DB_PASSWORD=
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_TRUST_CERT=yes
DB_QUERY_TIMEOUT=30
DB_MAX_ROWS=10000

# Domain selector (chooses which metadata/_schema.json is loaded)
DOMAIN=renty
